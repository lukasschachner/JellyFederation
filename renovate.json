{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":semanticCommits",
    ":dependencyDashboard",
    ":maintainLockFilesWeekly"
  ],
  "timezone": "Europe/Berlin",
  "enabledManagers": [
    "nuget",
    "npm",
    "dockerfile",
    "docker-compose",
    "github-actions"
  ],
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "prCreation": "immediate",
  "prConcurrentLimit": 8,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "matchManagers": [
        "nuget"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "nuget non-major updates"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "npm non-major updates"
    },
    {
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "groupName": "docker base image non-major updates"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "github actions non-major updates"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "dependencies",
        "major-update"
      ],
      "schedule": [
        "before 5am on the first day of the month"
      ]
    }
  ]
}
