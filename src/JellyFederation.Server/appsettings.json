{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AdminToken": "",
  "Urls": "http://0.0.0.0:5264",
  "ServerLimits": {
    "MaxRequestBodySizeMb": 10
  },
  "Database": {
    "Provider": "Sqlite",
    "AutoMigrate": true
  },
  "Telemetry": {
    "ServiceName": "jellyfederation-server",
    "OtlpEndpoint": "http://localhost:4317",
    "SamplingRatio": 1.0,
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableLogs": true,
    "RedactionEnabled": true
  }
}
